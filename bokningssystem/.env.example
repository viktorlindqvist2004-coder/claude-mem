# ═══ Bokningssystem — Konfiguration ═══
#
# Kopiera denna fil till .env och fyll i värdena.
#
# EmailJS (https://www.emailjs.com, gratis: 200 mail/mån)
# 1. Skapa konto och en e-posttjänst (Gmail, Outlook, etc.)
# 2. Skapa TVÅ mallar:
#    Kundbekräftelse  — variabler: to_email, to_name, service_name, booking_date, booking_time, booking_duration, booking_price, booking_id
#    Ägarnotifikation — variabler: to_email, customer_name, customer_email, customer_phone, service_name, booking_date, booking_time, booking_duration, booking_price, booking_id
# 3. Kopiera Service ID, Template IDs och Public Key nedan.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_CUSTOMER_TEMPLATE_ID=
VITE_EMAILJS_OWNER_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Mottagarens e-post (den som tar emot bokningsnotiser)
VITE_OWNER_EMAIL=din@email.se

# Företagsnamn (visas i rubriker och bekräftelser)
VITE_BUSINESS_NAME=Mitt Företag
